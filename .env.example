# ===========================================================================
# VietDub site — biến môi trường. Copy file này thành `.env.local` (chạy local)
# và khai báo y hệt trên Vercel → Project Settings → Environment Variables.
# KHÔNG commit file .env.local thật.
# ===========================================================================

# --- Sản phẩm / giá / khuyến mãi --------------------------------------------
# LƯU Ý: các giá trị này chỉ là MẶC ĐỊNH cho lần chạy đầu. Sau đó chúng được
# lưu vào tab "Settings" của Google Sheet và sửa được ở trang /admin (không cần
# deploy lại). Giá tính bằng VND, số nguyên.
PRODUCT_NAME=VietDub
BASE_PRICE=499000
PROMO_PRICE=249000
# Số ngày khuyến mãi tính từ lần seed đầu (dùng khi PROMO_ENDS_AT để trống).
PROMO_DAYS=7
# Hoặc đặt mốc kết thúc cụ thể (ISO), vd 2026-06-29T00:00:00+07:00. Trống = dùng PROMO_DAYS.
PROMO_ENDS_AT=
# Link tải bản Windows (.exe trên GitHub Releases). Đổi version khi ra bản mới.
DOWNLOAD_URL=https://github.com/kaisye/VietDubPublic/releases/latest/download/VietDub_0.1.7_x64-setup.exe
# Link tải bản macOS (.dmg, Apple Silicon). Khách chọn hệ điều hành khi thanh toán.
DOWNLOAD_URL_MAC=https://github.com/kaisye/VietDubPublic/releases/latest/download/VietDub_0.1.7_aarch64.dmg
# Link mời nhóm Zalo (lấy trong Zalo: nhóm > thêm thành viên > link mời).
ZALO_GROUP_URL=https://zalo.me/g/xxxxxxxxx
# Video demo trên trang chủ: link YouTube (youtu.be/... hoặc watch?v=...) hoặc .mp4.
# Để trống thì mục demo hiện ô chờ "sẽ sớm cập nhật". Sửa được ở /admin.
DEMO_VIDEO_URL=
# Trang Facebook giới thiệu các video đã dịch/lồng tiếng bằng tool. Hiện link ở
# mục Demo + footer. Để trống thì ẩn link. Sửa được ở /admin.
FACEBOOK_URL=

# Chế độ bảo trì: 1/true = bật trang bảo trì ở trang chủ + tạm dừng nhận đơn mới.
# Chỉ là giá trị seed lần đầu — bật/tắt nhanh ở /admin, không cần deploy lại.
MAINTENANCE=0
# Thông báo hiển thị khi bảo trì. Để trống = dùng câu mặc định.
MAINTENANCE_MESSAGE=

# --- Trang quản trị /admin --------------------------------------------------
# Mật khẩu vào trang dev /admin để sửa giá/khuyến mãi/link. Trống = tắt trang admin.
ADMIN_PASSWORD=

# --- URL site (dùng cho returnUrl/cancelUrl của PayOS) ----------------------
# Local: http://localhost:3000 | Production: https://vietdub.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- PayOS (https://my.payos.vn → Kênh thanh toán → API) --------------------
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# --- Google Sheets (lưu đơn hàng) ------------------------------------------
# ID nằm trong URL sheet: docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=
# Service account: tạo ở Google Cloud Console, bật Google Sheets API, tạo key JSON.
# Chia sẻ Google Sheet (quyền Editor) cho email service account này.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Dán nguyên private_key từ file JSON (giữ các \n). Bọc trong dấu nháy kép.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Email (Gmail SMTP — gửi link tải. Tùy chọn, để trống thì bỏ qua mail) --
# Bật xác minh 2 bước cho Gmail rồi tạo "App password" 16 ký tự.
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=
# Tên hiển thị người gửi
MAIL_FROM_NAME=VietDub

# --- Bảo mật webhook --------------------------------------------------------
# Chuỗi ngẫu nhiên bất kỳ; thêm vào URL webhook PayOS dạng ?token=... để chặn spam.
WEBHOOK_TOKEN=
